BINANCE_API_KEY="your_binance_api_key"
BINANCE_API_SECRET="your_binance_api_secret"

TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_CHAT_ID="54096783"

# Optional tuning
# EXCLUDE_SYMBOLS="BTCUSDT,ETHUSDT"
# MAX_CONCURRENT_POSITIONS="20"
# UNIVERSE_MAX_TOTAL="300"
# UNIVERSE_VOLUME_TOP_N="20"
# UNIVERSE_GAINER_POOL="300"
# UNIVERSE_MAX_TICK_PCT="0.004"
# LIQ_STOP_BUFFER_PCT="0.002"
# POSITION_RISK_PCT="0.01"
# DEFAULT_LEVERAGE="5"
# LEVERAGE_BTCUSDT="50"
# LEVERAGE_ETHUSDT="30"
# LEVERAGE_XRPUSDT="30"
# LEVERAGE_SOLUSDT="30"
# LEVERAGE_BNBUSDT="30"
#
# A-strategy filters
# EMA_ATR_OFFSET_MULT="0.9"
# ADX_MIN="21"
# ATR_PERIOD="14"
# ATR_SPIKE_CAP_MULT="1.8"
# (제거됨) EMA/RSI/ADX 기울기는 5봉 전 대비 순수 대소 비교만 사용
# CONFIRM_WITHIN_BARS="5"
# 기준봉 이후 상태머신 타임아웃(봉 수). 기본 7 (이전 5).
# STATE_TIMEOUT_BARS="7"
# 변동성: 직전 N봉 ATR 중앙값 × 배수 확장 + ATR/종가 하한(0=하한 끔)
# VOL_ATR_MEDIAN_WINDOW="20"
# VOL_ATR_MEDIAN_MULT="1.15"
# VOL_ATR_MIN_PCT_OF_CLOSE="0.0002"
# EXPLOSIVE_ATR_MULT="2.5"
# EXPLOSIVE_WAIT_BARS="2"
# EXPLOSIVE_TIMEOUT_BARS="12"
# OVERHEATED_ATR_MULT="3.0"
# OVERHEATED_RISK_RATIO="0.5"
# 초기 손절: 구조(BASIS) vs 진입가 최소거리(ENTRY_MIN) 중 더 넓은 쪽
# BASIS_SL_ATR_MULT="0.5"
# ENTRY_SL_MIN_ATR_MULT="1.0"
#
# 본절/트레일 (기본값은 config.py와 동일하게 맞춤)
# BREAKEVEN_LOCK_R_MULT="0.5"
# BREAKEVEN_ATR_MULT="0.25"
# TRAIL_ACTIVATE_R_MULT="0.6"
# TRAILING_ATR_MULT="3"
#
# WS 끊김 시 포지션 감시: 마크 REST 폴백 + 끊김 텔레그램 쿨다운
# MARK_PRICE_WS_STALE_SEC="30"
# MARK_PRICE_REST_MIN_INTERVAL_SEC="3"
# WS_DISCONNECT_TELEGRAM_COOLDOWN_SEC="180"
# WEBSOCKET_PING_INTERVAL="30"
# WEBSOCKET_PING_TIMEOUT="20"
# ATR_MIN_BTCUSDT="130"
# ATR_MIN_ETHUSDT="40"
# ATR_MIN_SOLUSDT="1.8"
# ATR_MIN_XRPUSDT="0.04"
